<audio id="loveMusic" loop>
    <source src="music.mp3" type="audio/mpeg">
</audio>

<div id="welcome" class="page">
    <h1>Welcome ❤️</h1>

    <input type="text" id="girlName" placeholder="Enter your name">

    <br><br>

    <select id="gender">
        <option value="">Select Gender</option>
        <option value="female">Female</option>
        <option value="male">Male</option>
    </select>

    <br><br>

    <button id="enterBtn">
        Continue ❤️
    </button>
</div>

<div id="malePage" class="page hidden">

    <h1>MISSION FAILED 😂</h1>

    <h2>
        Sorry bro, this page is not for you.
    </h2>

    <br>

    <video width="350" controls autoplay>
        <source src="mission.mp4" type="video/mp4">
    </video>

</div>

<div id="proposal" class="page hidden">

    <h1>
        I Like You
        <span id="showName"></span>
        ❤️
    </h1>

    <h2>
        Will you go on a date with me?
    </h2>

    <br>

    <button id="yesBtn">
        Yes ❤️
    </button>

    <button id="noBtn">
        No 😢
    </button>

</div>

<div id="thanks" class="page hidden">

    <h1 id="thanksName">
        Thank You ❤️
    </h1>

    <h2>
        Thank you for accepting my proposal.
    </h2>

    <br><br>

    <a href="https://instagram.com/who.is_sabbirr"
       target="_blank">

        <button>
            Message Me On Instagram ❤️
        </button>

    </a>

</div>

<script>

const enterBtn = document.getElementById("enterBtn");
const yesBtn = document.getElementById("yesBtn");
const noBtn = document.getElementById("noBtn");

const welcome = document.getElementById("welcome");
const proposal = document.getElementById("proposal");
const thanks = document.getElementById("thanks");
const malePage = document.getElementById("malePage");

const showName = document.getElementById("showName");

const loveMusic =
document.getElementById("loveMusic");

enterBtn.onclick = function(){

    const name =
    document.getElementById("girlName").value;

    const gender =
    document.getElementById("gender").value;

    if(name === "" || gender === ""){
        alert("Please enter name and gender.");
        return;
    }

    if(gender === "male"){

        welcome.classList.add("hidden");
        malePage.classList.remove("hidden");
        return;
    }

    loveMusic.play().catch(()=>{});

    showName.innerText = name;

    document.getElementById("thanksName")
    .innerText =
    "Thank You " + name + " ❤️";

    welcome.classList.add("hidden");
    proposal.classList.remove("hidden");
};

document.addEventListener("mousemove", function(e){

    const rect = noBtn.getBoundingClientRect();

    const dx =
    e.clientX - (rect.left + rect.width/2);

    const dy =
    e.clientY - (rect.top + rect.height/2);

    const distance =
    Math.sqrt(dx*dx + dy*dy);

    if(distance < 150){

        noBtn.style.left =
        Math.random() *
        (window.innerWidth - 100) + "px";

        noBtn.style.top =
        Math.random() *
        (window.innerHeight - 60) + "px";
    }
});

yesBtn.onclick = function(){

    proposal.classList.add("hidden");
    thanks.classList.remove("hidden");
};

</script>
